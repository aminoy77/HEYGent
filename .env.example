# Primary model: MiniMax M2.5 via Ollama cloud
# Get key at: https://ollama.com → Settings → API Keys
MINIMAX_API_KEY=your-ollama-api-key-here

# Fallback model: Trinity via OpenRouter (used when MiniMax is exhausted)
# Get key at: https://openrouter.ai → Keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Port (default 3001)
PORT=3001
